# ─── Project Wraeclast — environment template ───
# Copy to .env and fill in. NEVER commit the real .env.

# ── LLM (GLM via z.ai, OpenAI-compatible) ──
# Coding Plan -> coding endpoint. The general /paas endpoint needs separate balance.
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM_CHAT_MODEL=glm-5.2
GLM_CURATION_MODEL=glm-5.2
# z.ai Coding Plan has NO embeddings. Point EMBEDDINGS_* at a provider that does.
# Default: Gemini's OpenAI-compatible endpoint (free tier). gemini-embedding-001 is 3072-dim
# natively but is truncated to EMBEDDING_DIM (1024) to fit the DB column + pgvector hnsw.
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDING_DIM=1024

# ── Database (Neon Postgres + pgvector) ──
# postgresql://user:pass@host/dbname?sslmode=require
NEON_DATABASE_URL=

# ── poe.ninja (economy + builds, public; real PoE2 endpoints confirmed 2026-06-17) ──
# The economy API wants the league DISPLAY NAME (with spaces), e.g. "Runes of Aldur" — not slug.
# (WARNING: "Mirage" is a PoE1 league; PoE2 uses 0.x versioning. Confirm via `ninja_client explore`.)
POE2_LEAGUE=Runes of Aldur
NINJA_BASE_URL=https://poe.ninja
# PoE2 economy = currency-exchange overview (classic /api/data paths 404 for PoE2).
NINJA_ECONOMY_PATH=/poe2/api/economy/exchange/0/overview
NINJA_ECONOMY_TYPE=Currency
# PoE2 public profile characters: <base>/<account>/<version> -> JSON list of characters.
NINJA_PROFILE_PATH=/poe2/api/profile/characters
# Your poe.ninja account (dash form, e.g. Souzxx-4908). Blank NINJA_CHARACTER = auto-pick current.
NINJA_ACCOUNT=
NINJA_CHARACTER=

# ── Community knowledge sources ──
# YouTube Data API v3 key (official, free): console.cloud.google.com -> enable
# "YouTube Data API v3" -> Create API key. The richest legitimate farming source.
YOUTUBE_API_KEY=
# Optional overrides:
# YOUTUBE_QUERIES=Path of Exile 2 farming strategy,PoE2 best currency farm
# RSS/Atom feeds (comma-separated, optional). Syndication is fine to consume.
RSS_FEEDS=

# ── Reddit (DORMANT — requires Reddit approval; restricted for AI use; not in daily flow) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── GGG OAuth (Phase 2 — OPTIONAL, only if approved) ──
GGG_CLIENT_ID=
GGG_CLIENT_SECRET=
GGG_REDIRECT_URI=
GGG_USER_AGENT=Project-Wraeclast/0.1 (contact: souzxxx)

# ── API server ──
# Shared secret protecting the internal "run daily collection" endpoint (called by cron).
INTERNAL_RUN_TOKEN=
# Password gating /chat (the only endpoint that spends GLM/embeddings). Enter it once in the
# site. If empty, /chat is disabled (fail-closed). Generate: openssl rand -hex 24
CHAT_ACCESS_TOKEN=
# Comma-separated allowed origins for the web frontend.
CORS_ORIGINS=http://localhost:3000

# ── Obsidian export ──
OBSIDIAN_VAULT_DIR=./vault
