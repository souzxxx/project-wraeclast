# ─── Project Wraeclast — environment template ───
# Copy to .env and fill in. NEVER commit the real .env.

# ── LLM (GLM via z.ai, OpenAI-compatible) ──
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/openai/v1
GLM_CHAT_MODEL=glm-4.7-flash
GLM_CURATION_MODEL=glm-4.7-flash
# Embeddings model (z.ai). If z.ai has no embeddings tier, point EMBEDDINGS_* at any
# OpenAI-compatible provider. Vector dim must match the DB column (see EMBEDDING_DIM).
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://api.z.ai/api/openai/v1
EMBEDDINGS_MODEL=embedding-2
EMBEDDING_DIM=1024

# ── Database (Neon Postgres + pgvector) ──
# postgresql://user:pass@host/dbname?sslmode=require
NEON_DATABASE_URL=

# ── poe.ninja (economy + builds, public) ──
# PoE2 league. Set to the current PoE2 0.5.0 challenge league.
# WARNING: "Mirage" is a PoE1 league (PoE1 uses 3.x versioning) — do NOT use it here.
# Confirm the exact poe.ninja slug with: python -m collector.ninja_client explore
POE2_LEAGUE=Return of the Ancients
# Base URL + endpoint templates are config-driven because poe.ninja's PoE2 site is an
# Astro SPA and the classic /api/data paths 404 publicly. Confirm with the `explore`
# command in the deploy environment, then set these.
NINJA_BASE_URL=https://poe.ninja
NINJA_ECONOMY_PATH=/api/data/currencyoverview
NINJA_ITEM_PATH=/api/data/itemoverview
NINJA_BUILDS_BASE=https://poe.ninja/poe2/builds
# Your linked poe.ninja profile / character to track for the build diff.
NINJA_ACCOUNT=
NINJA_CHARACTER=

# ── Community scraper (Reddit) ──
REDDIT_USER_AGENT=Project-Wraeclast/0.1 (contact: souzxxx)
REDDIT_SUBREDDIT=PathOfExile2
# Optional: registered Reddit app for the official API (else falls back to public .json).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
SCRAPER_MIN_SCORE=25
SCRAPER_MAX_AGE_DAYS=7

# ── GGG OAuth (Phase 2 — OPTIONAL, only if approved) ──
GGG_CLIENT_ID=
GGG_CLIENT_SECRET=
GGG_REDIRECT_URI=
GGG_USER_AGENT=Project-Wraeclast/0.1 (contact: souzxxx)

# ── API server ──
# Shared secret protecting the internal "run daily collection" endpoint (called by cron).
INTERNAL_RUN_TOKEN=
# Comma-separated allowed origins for the web frontend.
CORS_ORIGINS=http://localhost:3000

# ── Obsidian export ──
OBSIDIAN_VAULT_DIR=./vault
